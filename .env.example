# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Postgres (TypeORM)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=idola_stekom
# true only for local dev — auto-syncs schema from entities
DB_SYNC=true

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Google SSO (voter login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Storage: local (default) | s3 (MinIO/R2/Spaces/AWS)
STORAGE_DRIVER=local
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
# URL publik file (CDN/custom domain). Kosong = endpoint/bucket
S3_PUBLIC_URL=

# Depot media backend (STORAGE_DRIVER=depot)
DEPOT_BASE_URL=
DEPOT_API_KEY=
DEPOT_WEBHOOK_SECRET=

# API key aplikasi kedua (web pendaftaran)
INTEGRATION_API_KEY=
